PORT=8000
WEBSITE_URL=https://www.sg-web.tekjuice.xyz/

JWT_SECRET=your_jwt_secret_here
AWS_S3_BUCKET_NAME=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

HOST_NAME=localhost
USER_NAME=root
PASSWORD=your_db_password
DBNAME=social_gems
REDIS_DB_URL=redis://localhost:6379
SITE_URL=https://sg-web.tekjuice.xyz
API_URL=https://gems.tekjuice.xyz
FL_SECRETE=your_flutterwave_secret_key

SES_ACCESS_SECRETE=your_ses_secret
SES_ACCESS_KEY=your_ses_access_key
SES_AWS_REGION=us-east-2
SES_SMTP_URL=email-smtp.us-east-2.amazonaws.com
SES_SMTP_PORT=587
SES_SMT_USER=your_ses_smtp_username
SES_SMT_PASSWORD=your_ses_smtp_password
SES_SMT_IAM=your_ses_iam_user
SES_FROM=no-reply@example.com

SOCIAL_GEMS_CHANNEL=your_social_gems_channel_id

X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret
# Must exactly match the callback configured in the X developer portal.
X_REDIRECT_URI=https://your-socialgems-api.example.com/oauth/oauth2redirect
FACEBOOK_REDIRECT_URI=https://your-socialgems-api.example.com/oauth/oauth2redirect
# Deep link opened by /oauth/oauth2redirect after X returns to the backend.
APP_DEEP_LINK=socialgems://app.socialgems.me

MAILGUN_SMTP_USER=your_smtp_username
MAILGUN_SMTP_PASSWORD=your_smtp_password
SMTP_HOST=mail.smtp2go.com
MAILGUN_SMTP_FROM=no-reply@socialgems.me

RAPIDAPI_KEY=your_rapidapi_key

SMS_KEY=your_sms_key
SMS_USER=your_sms_user
ADMIN_WALLET=0X0000000000
FCM_ENDPOINT=https://fcm.googleapis.com/v1/projects/app-social-gems/messages:send

NEWS_API=your_news_api_key
NEWS_URL=https://newsapi.org/v2/top-headlines

STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key
NODE_ENV=local

RELWORX_API_KEY=your_relworx_api_key
RELWORX_URL=https://payments.relworx.com/api/mobile-money
REL_ACCOUNT_NUMBER=REL2B00039A94

# Payment orchestration.
# Leave PAYMENT_PROVIDER unset/direct to use the existing Relworx + Stripe paths.
# Set PAYMENT_PROVIDER=gempay to route mobile deposits and KES withdrawals through Gempay.
PAYMENT_PROVIDER=direct
GEMPAY_BASE_URL=http://localhost:9000
GEMPAY_BEARER_TOKEN=your_gempay_jwt_or_service_token
GEMPAY_DEPOSIT_PATH=/pay/merchant/deposit
GEMPAY_PAYOUT_PATH=/pay/merchant/payout
GEMPAY_SOCIALGEMS_WEBHOOK_URL=https://your-socialgems-api.example.com/wallet/webhook_gempay
GEMPAY_WEBHOOK_TOKEN=shared_webhook_token
GEMPAY_TIMEOUT_MS=30000

ENVIRONMENT=local
